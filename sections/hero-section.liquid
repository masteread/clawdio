{% schema %}
  {
    "name": "Hero Section",
    "settings": [
      {
        "type": "text",
        "id": "heading",
        "label": "Heading",
        "default": "Welcome to our Store"
      },
      {
        "type": "richtext",
        "id": "subheading",
        "label": "Subheading",
        "default": "<p>Discover amazing products</p>"
      },
      {
        "type": "url",
        "id": "button_link",
        "label": "Button Link"
      },
      {
        "type": "text",
        "id": "button_label",
        "label": "Button Label",
        "default": "Shop Now"
      }
    ],
    "presets": [
      {
        "name": "Hero Section"
      }
    ]
  }
{% endschema %}

<section class="hero-section">
  <h1>{{ section.settings.heading }}</h1>
  <div>{{ section.settings.subheading }}</div>
  {% if section.settings.button_link != blank and section.settings.button_label != blank %}
    <a href="{{ section.settings.button_link }}">{{ section.settings.button_label }}</a>
  {% endif %}
</section>

