{% schema %}
  {
    "name": "Hero Section",
    "settings": [
      {
        "type": "text",
        "id": "heading",
        "label": "Heading",
        "default": "Experience the Art of Coffee"
      },
      {
        "type": "richtext",
        "id": "subheading",
        "label": "Subheading",
        "default": "<p>Freshly roasted, ethically sourced beans delivered to your door.</p>"
      },
      {
        "type": "url",
        "id": "button_link",
        "label": "Button Link"
      },
      {
        "type": "text",
        "id": "button_label",
        "label": "Button Label",
        "default": "Shop Our Coffees"
      },
      {
        "type": "image_picker",
        "id": "background_image",
        "label": "Background Image"
      }
    ],
    "presets": [
      {
        "name": "Coffee Hero Section",
        "settings": {
          "heading": "Experience the Art of Coffee",
          "subheading": "<p>Freshly roasted, ethically sourced beans delivered to your door.</p>",
          "button_label": "Shop Our Coffees",
          "button_link": "/collections/all"
        }
      }
    ]
  }
{% endschema %}

<section class="hero-section" style="{% if section.settings.background_image != blank %}background-image: url({{ section.settings.background_image | image_url: width: 1920 }});{% else %}background-image: url(https://cdn.shopify.com/s/files/1/0XXXX/XXXX/files/coffee-hero-placeholder.jpg);{% endif %} background-size: cover; background-position: center;">
  <div class="hero-content">
    <h1>{{ section.settings.heading | default: "Experience the Art of Coffee" }}</h1>
    <div>{{ section.settings.subheading | default: "<p>Freshly roasted, ethically sourced beans delivered to your door.</p>" }}</div>
    {% if section.settings.button_link != blank and section.settings.button_label != blank %}
      <a href="{{ section.settings.button_link }}">{{ section.settings.button_label }}</a>
    {% endif %}
  </div>
</section>

<style>
  .hero-section {
    color: white;
    text-shadow: 2px 2px 4px rgba(0,0,0,0.5);
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 500px; /* Increased height for impact */
    position: relative;
  }
  .hero-section::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    background: rgba(0,0,0,0.4); /* Darker overlay for readability */
    z-index: 1;
  }
  .hero-content {
    position: relative;
    z-index: 2;
    max-width: 800px;
    padding: 20px;
  }
  .hero-section h1 {
    font-size: 3.5em;
  }
  .hero-section p {
    font-size: 1.3em;
  }
</style>
