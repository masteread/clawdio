{% schema %}
  {
    "name": "Footer",
    "settings": [
      {
        "type": "richtext",
        "id": "copyright_text",
        "label": "Copyright Text",
        "default": "<p>&copy; {{ 'now' | date: \"%Y\" }} Coffee Roasters Inc.</p>"
      }
    ],
    "blocks": [
      {
        "type": "link_list",
        "name": "Menu",
        "settings": [
          {
            "type": "text",
            "id": "heading",
            "label": "Heading",
            "default": "Quick Links"
          },
          {
            "type": "link_list",
            "id": "menu",
            "label": "Menu to display"
          }
        ]
      },
      {
        "type": "text_block",
        "name": "Text Block",
        "settings": [
          {
            "type": "text",
            "id": "heading",
            "label": "Heading",
            "default": "About Our Coffee"
          },
          {
            "type": "richtext",
            "id": "text",
            "label": "Text",
            "default": "<p>We are a passionate team dedicated to sourcing and roasting the finest coffee beans for you.</p>"
          }
        ]
      }
    ],
    "presets": [
      {
        "name": "Coffee Footer",
        "blocks": [
          {
            "type": "link_list",
            "settings": {
              "heading": "Customer Service",
              "menu": "footer" /* Assuming 'footer' is a handle for a link list in Shopify navigation */
            }
          },
          {
            "type": "link_list",
            "settings": {
              "heading": "Information",
              "menu": "main-menu" /* Assuming 'main-menu' is a handle for a link list */
            }
          },
          {
            "type": "text_block",
            "settings": {
              "heading": "Stay Connected",
              "text": "<p>Follow us on social media for fresh roasts and special offers!</p>"
            }
          }
        ]
      }
    ]
  }
{% endschema %}

<footer class="footer-section">
  <div class="page-width">
    <div class="footer-content">
      {% for block in section.blocks %}
        {% case block.type %}
          {% when 'link_list' %}
            <div class="footer-menu">
              <h3>{{ block.settings.heading | default: "Quick Links" }}</h3>
              <ul>
                {% for link in block.settings.menu.links %}
                  <li><a href="{{ link.url }}">{{ link.title }}</a></li>
                {% else %}
                  {% comment %} Dummy links if no menu is selected {% endcomment %}
                  <li><a href="#">Our Story</a></li>
                  <li><a href="#">FAQs</a></li>
                  <li><a href="#">Contact</a></li>
                {% endfor %}
              </ul>
            </div>
          {% when 'text_block' %}
            <div class="footer-text-block">
              <h3>{{ block.settings.heading | default: "About Our Coffee" }}</h3>
              <div>{{ block.settings.text | default: "<p>Dedicated to ethical sourcing and exceptional taste, we bring the world's best coffee to your cup.</p>" }}</div>
            </div>
        {% endcase %}
      {% endfor %}
    </div>
    <div class="footer-copyright">
      {{ section.settings.copyright_text | default: "<p>&copy; 2026 Coffee Roasters Inc.</p>" }}
    </div>
  </div>
</footer>

<style>
  /* Styles moved to assets/styles.css for better organization */
</style>
