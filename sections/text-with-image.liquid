{% schema %}
  {
    "name": "Text with Image",
    "settings": [
      {
        "type": "image_picker",
        "id": "image",
        "label": "Image"
      },
      {
        "type": "select",
        "id": "image_position",
        "label": "Image Position",
        "options": [
          { "value": "left", "label": "Left" },
          { "value": "right", "label": "Right" }
        ],
        "default": "left"
      },
      {
        "type": "text",
        "id": "heading",
        "label": "Heading",
        "default": "Our Passion for Coffee"
      },
      {
        "type": "richtext",
        "id": "text",
        "label": "Text",
        "default": "<p>We are dedicated to bringing you the finest coffee beans from around the world. Each bean is hand-picked and expertly roasted to perfection, ensuring a rich and aromatic experience with every cup. Discover our sustainable and ethical sourcing practices.</p>"
      }
    ],
    "presets": [
      {
        "name": "Coffee Story",
        "settings": {
          "heading": "Our Passion for Coffee",
          "text": "<p>We are dedicated to bringing you the finest coffee beans from around the world. Each bean is hand-picked and expertly roasted to perfection, ensuring a rich and aromatic experience with every cup. Discover our sustainable and ethical sourcing practices.</p>"
        }
      }
    ]
  }
{% endschema %}

<section class="text-with-image {% if section.settings.image_position == 'right' %}image-right{% endif %}">
  <div class="page-width">
    {% if section.settings.image != blank %}
      <div class="image-wrapper">
        <img src="{{ section.settings.image | image_url: width: 600 }}" alt="{{ section.settings.image.alt | escape }}">
      </div>
    {% else %}
       <div class="image-wrapper">
          <img src="https://cdn.shopify.com/s/files/1/0XXXX/XXXX/files/coffee-beans-placeholder.jpg" alt="Coffee Beans">
       </div>
    {% endif %}
    <div class="text-wrapper">
      <h2>{{ section.settings.heading | default: "Our Passion for Coffee" }}</h2>
      <div>{{ section.settings.text | default: "<p>We are dedicated to bringing you the finest coffee beans from around the world. Each bean is hand-picked and expertly roasted to perfection, ensuring a rich and aromatic experience with every cup. Discover our sustainable and ethical sourcing practices.</p>" }}</div>
    </div>
  </div>
</section>

<style>
  /* Styles moved to assets/styles.css for better organization */
</style>
