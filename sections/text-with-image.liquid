{% schema %}
  {
    "name": "Text with Image",
    "settings": [
      {
        "type": "image_picker",
        "id": "image",
        "label": "Image"
      },
      {
        "type": "select",
        "id": "image_position",
        "label": "Image Position",
        "options": [
          { "value": "left", "label": "Left" },
          { "value": "right", "label": "Right" }
        ],
        "default": "left"
      },
      {
        "type": "text",
        "id": "heading",
        "label": "Heading",
        "default": "Title of Section"
      },
      {
        "type": "richtext",
        "id": "text",
        "label": "Text",
        "default": "<p>Add your descriptive text here.</p>"
      }
    ],
    "presets": [
      {
        "name": "Text with Image"
      }
    ]
  }
{% endschema %}

<section class="text-with-image {% if section.settings.image_position == 'right' %}image-right{% endif %}">
  {% if section.settings.image != blank %}
    <div class="image-wrapper">
      <img src="{{ section.settings.image | image_url: width: 600 }}" alt="{{ section.settings.image.alt | escape }}">
    </div>
  {% else %}
     <div class="image-wrapper">
        <img src="https://cdn.shopify.com/s/files/1/0533/2088/files/placeholder-image.png" alt="Placeholder Image">
     </div>
  {% endif %}
  <div class="text-wrapper">
    <h2>{{ section.settings.heading | default: "Our Story and Mission" }}</h2>
    <div>{{ section.settings.text | default: "<p>At our core, we believe in delivering exceptional quality and unparalleled customer service. Every product is crafted with passion and precision, ensuring you receive only the best. Join us on our journey to innovate and inspire.</p>" }}</div>
  </div>
</section>

<style>
  .text-with-image {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 30px;
  }
  .text-with-image.image-right {
    flex-direction: row-reverse; /* Image on right */
  }
  .text-with-image .image-wrapper, .text-with-image .text-wrapper {
    flex: 1;
    min-width: 300px; /* Adjust as needed */
  }
  .text-with-image img {
    max-width: 100%;
    height: auto;
    border-radius: 8px;
  }
</style>
