{% schema %}
  {
    "name": "Testimonials",
    "settings": [
      {
        "type": "text",
        "id": "heading",
        "label": "Heading",
        "default": "What Our Customers Say About Our Coffee"
      }
    ],
    "blocks": [
      {
        "type": "testimonial",
        "name": "Testimonial",
        "settings": [
          {
            "type": "richtext",
            "id": "quote",
            "label": "Quote",
            "default": "<p>This is an amazing product!</p>"
          },
          {
            "type": "text",
            "id": "author",
            "label": "Author",
            "default": "Customer Name"
          }
        ]
      }
    ],
    "presets": [
      {
        "name": "Coffee Testimonials",
        "blocks": [
          {
            "type": "testimonial",
            "settings": {
              "quote": "<p>\"The aroma alone is enough to wake me up with a smile. Best coffee I've ever tasted!\"</p>",
              "author": "Coffee Lover Jane D."
            }
          },
          {
            "type": "testimonial",
            "settings": {
              "quote": "<p>\"Finally, a coffee that matches my high standards. Rich, smooth, and perfectly roasted.\"</p>",
              "author": "Barista John S."
            }
          },
          {
            "type": "testimonial",
            "settings": {
              "quote": "<p>\"Their subscription service is a game-changer. Fresh coffee, no fuss, every month!\"</p>",
              "author": "Daily Brew Emily R."
            }
          }
        ]
      }
    ]
  }
{% endschema %}

<section class="testimonials-section">
  <h2>{{ section.settings.heading | default: "Voices of Coffee Enthusiasts" }}</h2>
  <div class="testimonials-grid">
    {% if section.blocks.size > 0 %}
      {% for block in section.blocks %}
        <div class="testimonial-item">
          <div class="quote">{{ block.settings.quote }}</div>
          <p class="author">- {{ block.settings.author }}</p>
        </div>
      {% endfor %}
    {% else %}
      {% comment %} Dummy testimonials if no blocks are configured {% endcomment %}
      <div class="testimonial-item">
        <div class="quote"><p>"This coffee makes my mornings so much better! A truly delightful experience."</p></div>
        <p class="author">- Happy Customer</p>
      </div>
      <div class="testimonial-item">
        <div class="quote"><p>"I'm impressed by the quality and the smooth finish. Will definitely reorder."</p></div>
        <p class="author">- Satisfied Sipper</p>
      </div>
    {% endif %}
  </div>
</section>
