{% schema %}
  {
    "name": "Contact Form",
    "settings": [
      {
        "type": "text",
        "id": "heading",
        "label": "Heading",
        "default": "Contact Us"
      },
      {
        "type": "richtext",
        "id": "description",
        "label": "Description",
        "default": "<p>We\'d love to hear from you!</p>"
      },
      {
        "type": "text",
        "id": "google_sheets_api_endpoint",
        "label": "Google Sheets API Endpoint (e.g., Serverless Function URL)",
        "info": "This should be the URL of your serverless function or custom API that handles Google Sheets integration.",
        "default": "YOUR_GOOGLE_SHEETS_API_ENDPOINT"
      }
    ],
    "presets": [
      {
        "name": "Contact Form"
      }
    ]
  }
{% endschema %}

<section class="contact-form-section">
  <h2>{{ section.settings.heading }}</h2>
  <div>{{ section.settings.description }}</div>

  <form id="contactForm" class="contact-form">
    <input type="text" name="name" placeholder="Your Name" required>
    <input type="email" name="email" placeholder="Your Email" required>
    <textarea name="message" placeholder="Your Message" rows="5" required></textarea>
    <button type="submit">Send Message</button>
    <p id="formStatus"></p>
  </form>
</section>

<script>
  document.getElementById('contactForm').addEventListener('submit', async function(event) {
    event.preventDefault();

    const formStatus = document.getElementById('formStatus');
    formStatus.textContent = 'Sending...';
    formStatus.style.color = 'orange';

    const formData = new FormData(event.target);
    const payload = {};
    for (let [key, value] of formData.entries()) {
      payload[key] = value;
    }

    const endpoint = '{{ section.settings.google_sheets_api_endpoint }}';

    if (endpoint === 'YOUR_GOOGLE_SHEETS_API_ENDPOINT' || !endpoint) {
      formStatus.textContent = 'Error: Google Sheets API Endpoint is not configured.';
      formStatus.style.color = 'red';
      return;
    }

    try {
      const response = await fetch(endpoint, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'Accept': 'application/json'
        },
        body: JSON.stringify(payload)
      });

      if (response.ok) {
        formStatus.textContent = 'Message sent successfully!';
        formStatus.style.color = 'green';
        event.target.reset(); // Clear the form
      } else {
        const errorData = await response.json();
        formStatus.textContent = 'Error sending message: ' + (errorData.message || 'Unknown error');
        formStatus.style.color = 'red';
      }
    } catch (error) {
      formStatus.textContent = 'Network error: ' + error.message;
      formStatus.style.color = 'red';
    }
  });
</script>
