{% schema %}
  {
    "name": "Product Grid",
    "settings": [
      {
        "type": "text",
        "id": "title",
        "label": "Heading",
        "default": "Our Exclusive Coffee Selection"
      },
      {
        "type": "collection",
        "id": "collection",
        "label": "Collection to display"
      },
      {
        "type": "range",
        "id": "products_to_show",
        "min": 2,
        "max": 12,
        "step": 1,
        "label": "Products to show",
        "default": 4
      }
    ],
    "presets": [
      {
        "name": "Coffee Products",
        "settings": {
          "title": "Our Exclusive Coffee Selection"
        }
      }
    ]
  }
{% endschema %}

<section class="product-grid">
  <h2>{{ section.settings.title | default: "Our Exclusive Coffee Selection" }}</h2>
  <div class="product-items">
    {% comment %}
      Demonstration products if no collection is selected or products are missing.
      In a real Shopify store, this would dynamically pull from the collection.
    {% endcomment %}
    {% assign products_to_display = section.settings.collection.products | default: false %}

    {% if products_to_display != false and products_to_display.size > 0 %}
      {% for product in products_to_display limit: section.settings.products_to_show %}
        <div class="product-item">
          <a href="{{ product.url }}">
            <img src="{{ product.featured_image | image_url: width: 300 }}" alt="{{ product.featured_image.alt | escape }}">
            <h3>{{ product.title }}</h3>
            <p>{{ product.price | money }}</p>
          </a>
        </div>
      {% endfor %}
    {% else %}
      {% comment %} Dummy products for demonstration if no collection is set {% endcomment %}
      {% assign dummy_products = "Espresso Blend,Ethiopian Yirgacheffe,Colombian Supremo,Decaf House Blend,Sumatra Mandheling,Guatemala Antigua" | split: "," %}
      {% for i in (0..section.settings.products_to_show | minus: 1) %}
        {% assign product_name = dummy_products[i | modulo: dummy_products.size] %}
        <div class="product-item">
          <a href="#">
            <img src="https://cdn.shopify.com/s/files/1/0XXXX/XXXX/files/coffee-product-placeholder-{{ i | plus: 1 }}.jpg" alt="{{ product_name }}">
            <h3>{{ product_name }}</h3>
            <p>${{ 10 | plus: i }}.99</p>
          </a>
        </div>
      {% endfor %}
    {% endif %}
  </div>
</section>
